{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "documentation/rules/rules.md"
  ],
  "mcp": {
    "browser": {
      "enabled": true,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--browser=chrome",
        "--isolated"
      ]
    },
    "authenticated_browser": {
      "enabled": true,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--browser=chrome",
        "--user-data-dir=/Users/ma5bah/Library/Application Support/Google/Chrome/Profile 1"
      ]
    },
    "burp_browser": {
      "enabled": true,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--browser=chrome",
        "--isolated",
        "--proxy-server=http://127.0.0.1:8080"
      ]
    },
    "burp": {
      "type": "remote",
      "url": "http://127.0.0.1:9876"
    },
    "ssh_havementor": {
      "type": "local",
      "enabled": true,
      "command": [
        "/Users/ma5bah/project/brain/mcp/ssh/target/release/ssh-mcp",
        "--host",
        "16.112.56.29",
        "-u",
        "ubuntu",
        "-i",
        "/Users/ma5bah/.ssh/havementor.pem",
        "--command-timeout-secs",
        "60"
      ]
    },
    "codebase-memory-mcp": {
        "enabled": true,
        "type": "local",
        "command": [
            "/Users/ma5bah/.local/bin/codebase-memory-mcp",
            "--ui=true"
        ]
    }
  },
  "plugin": [],
  "agent": {
    "orchestrator": {
      "mode": "primary",
      "model": "opencode-go/mimo-v2.5-pro",
