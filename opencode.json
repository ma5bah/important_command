    },
    "bug_hunter": {
      "description": "Bug Bounty Hunter \u2014 recon through verified findings.",
      "mode": "primary",
      "model": "opencode-go/mimo-v2.5",
      "prompt": "{file:/Users/ma5bah/project/brain/documentation/prompt/bug_hunter.md}"
