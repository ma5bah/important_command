      "description": "Actor for executing well-defined mechanical generation tasks.",
      "mode": "subagent",
      "model": "opencode-go/mimo-v2.5",
      "prompt": "{file:/Users/ma5bah/project/brain/documentation/prompt/executor-prompt.md}"
